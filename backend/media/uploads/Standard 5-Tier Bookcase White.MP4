            liveFlagshipStates["amazonlive-react-weblab-v2-data"] = JSON.parse("{\"AL_OSA_INSTRN_357138\":\"T1\",\"AL_FS_FOR_YOU_677535\":\"C\",\"AL_FS_SKIP_1ST_SEGMENT_712620\":\"C\",\"AL_UNMUTED_AUTOPLAY_E_753832\":\"T1\",\"ANP_ASV_CREATOR_DISCLAIMER_TEXT_1365760\":\"T1\",\"AL_CAT_HOTLOAD_749062\":\"T1\",\"PD_DO_CODE_334337\":\"C\",\"ASV_FS_TRIMMING_ENABLED_E_862292\":\"T1\",\"ASV_ALSS_DEP_CAROUSEL_V2_1353937\":\"T1\",\"ASV_WEB_PURCHASE_AIDS_E_641914\":\"T1\",\"AL_CAT_HOTLOAD_710936\":\"T1\",\"AL_FS_NOTIFICATIONS_632373\":\"T1\",\"ASV_BRAND_UPDATE_1036468\":\"T1\",\"ANP_AGGRESSIVE_PREWARMING_1230138\":\"T1\",\"ASV_CREATOR_WALLET_608120\":\"T1\",\"PEAS_DO_CONTENT_489637\":\"C\",\"ASV_FS_INITIALIZE_VSE_CONTENT_L_882828\":\"C\",\"AL_GW_PL_569977\":\"C\",\"AL_GW_ORC_VPL_390257\":\"T1\",\"A2I_AL_FS_CAROUSEL_MODULARISATION_L_942739\":\"T1\",\"ASV_ALSS_DEP_SHOPPING_CAROUSEL_V2_1353935\":\"T1\",\"AMAZON_LIVE_FLAGSHIP_G2G_LATENCY_REPORT_869538\":\"C\",\"ASV_FS_FOLLOW_V3_MIGRATION_1162010\":\"T1\",\"A2I_PREFETCH_PREWARM_CATAMARAN_E_719019\":\"T2\",\"ASV_MWEB_REDIRECT_P3_1099309\":\"T1\",\"ASV_FS_REACTIONS_610697\":\"T1\",\"AL_CAT_DEST_L_372258\":\"T1\",\"ASV_CLAIM_PROMO_CODE_EP_434062\":\"T1\",\"PBDD_DO_CODE_745375\":\"C\",\"ASV_CAROUSEL_ADD_TO_CART_1106000\":\"T1\",\"ASV_PORTAL_1124839\":\"C\",\"ASV_FS_TRANSCRIPTS_1291783\":\"T1\",\"ASV_WEB_REALTIME_METRICS_638605\":\"T1\",\"AL_FS_CA_INGRESS_670085\":\"C\",\"ASV_FS_IC_CONTRACT_713170\":\"T1\",\"AL_SE_BD_306329\":\"C\",\"ASV_FLAGSHIP_PL_BADGE_1157031\":\"C\",\"ASV_ALSS_DEP_BROADCASTEVENTS_1353931\":\"T1\",\"AL_PL_GW_ORC_L_338858\":\"T1\",\"ASV_MWEB_REDIRECT_FS_1189405\":\"T1\",\"ASV_FS_SOCIAL_PLAYER_IMPROVEMENTS_1368280\":\"T1\",\"ASV_CATEGORY_PLACEMENT_AUTOMATION_ENABLED_1110307\":\"T1\",\"ASV_FS_SPONSORED_PRODUCTS_LIVE_LAUNCH_1300130\":\"C\",\"A2I_PREFETCH_PREWARM_CATAMARAN_IOS_E_748158\":\"T2\",\"ASV_ANP_PREW_AND_1028605\":\"T2\"}");
        
            liveFlagshipStates["amazonlive-react-transcript-display-flag-data"] = JSON.parse("true");
        
        liveFlagshipStates["pollingOptions"] = {};
        
            liveFlagshipStates["pollingOptions"]["IS_POLL_ENABLED"] = JSON.parse("true");
        
            liveFlagshipStates["pollingOptions"]["IS_IN_VIEW_POLL_ENABLED"] = JSON.parse("true");
        
            liveFlagshipStates["pollingOptions"]["POLL_DEAL_PRODUCT_DATA_INTERVAL"] = JSON.parse("12");
        
            liveFlagshipStates["pollingOptions"]["POLL_PRODUCT_DATA_INTERVAL"] = JSON.parse("60");
        
        liveFlagshipStates["themingOptions"] = {};
        
            liveFlagshipStates["themingOptions"]["WIDGET_PRIMARY_COLOR"] = "#FFFFFF";
        
            liveFlagshipStates["themingOptions"]["WIDGET_SECONDARY_COLOR"] = "#FF6200";
        
            liveFlagshipStates["themingOptions"]["WIDGET_TEXT_COLOR"] = "#000000";
        
            liveFlagshipStates["themingOptions"]["WIDGET_SCROLLBAR_COLOR"] = "#C1C1C1";
        
        
        // Image optimization parameters that must match the player's poster image URL to prevent duplicate image requests
        const IMAGE_PROCESSING_PARAMS = '._QL85_AC_SCLZZZZZZZ_';
        const FILE_EXTENSION_REGEX = /(\.[^.]+)$/;
        const PLAYLIST_DATA_KEY = 'amazonlive-react-playlist-data';

        /**
         * Extracts and transforms the slate image URL from a playlist container.
         * @param {Object} playlistContainer - The container object holding playlist data
         * @returns {string|undefined} The processed slate image URL, or undefined if unavailable
        */
        function getSlateImageUrl(playlistContainer) {
            const playlistData = playlistContainer && playlistContainer[PLAYLIST_DATA_KEY];
            const slateImageId = Array.isArray(playlistData) && playlistData[0] && playlistData[0].slateImageId;

            return slateImageId
                ? slateImageId.replace(FILE_EXTENSION_REGEX, IMAGE_PROCESSING_PARAMS + '$1')
                : undefined;
        }
        
        // Preload slate image for LCP (Largest Contentful Paint) optimization
        const widgetOptionsData = liveFlagshipStates["amazonlive-react-widget-options-data"] || {};
        
        // Check if the slate image preload widget option is true from ASVH
        if (widgetOptionsData["enableSlateImagePreload"]) {
            const playlistContainer = liveFlagshipStates[PLAYLIST_DATA_KEY];
            const processedSlateImageUrl = getSlateImageUrl(playlistContainer);
            
            if (processedSlateImageUrl) {
                const preloadLink = document.createElement('link');
                preloadLink.rel = 'preload';
                preloadLink.as = 'image';
                preloadLink.fetchPriority = 'high';
                preloadLink.href = processedSlateImageUrl;
                
                document.head.appendChild(preloadLink);
            }
        }
        
        const isWidgetAlreadyRegistered = () => {
            var isRegistered = false;
            P.now('amazonlive:widget:initialized').execute(function (module) {
                isRegistered = !!module;
            });
            return isRegistered;
        }
        const initLiveWidget = (initializeLiveWidget) => {
            if (!isWidgetAlreadyRegistered()) {
                
                const placeholderExperienceEnabled = liveFlagshipStates["amazonlive-react-widget-options-data"]["isPlaceholderThumbnailEnabled"];
                if (placeholderExperienceEnabled) {
                    rootElement.innerHTML = '';
                }
                var widget = initializeLiveWidget(liveFlagshipStates, "live-flagship-root");
                window.P.when('A').execute('amazonlive-flagship-debug', function(A) {
                    A.on('amazonlive:debug', function(callback) {
                        callback({
                           initialState: liveFlagshipStates,
                           currentState: widget.getState(),
                        });
                    });
                });
                // checks if value is in the format number followed by px or % eg: 100px or 20%
                var widgetHeightRegex = /\d*\.?\d+(?:px|%)?/i;
                if (("none").match(widgetHeightRegex)){
                           rootElement.style.maxHeight="none";
                           rootElement.style.overflowY="hidden";
                }
                window.P.trigger('amazonlive:widget:initialized');
            } else if (window.ue && window.ue.count) {
                window.ue.count("LiveWidgetMultipleInitializationAttempted", 1);
            }
        };
        if (false){
            P.when('amazon-live-widget-library').execute(function(amazonLiveLibrary) {
                initLiveWidget(amazonLiveLibrary.initializeWidget);
            })
        }else {
            if (window.initLivePage) {
                initLiveWidget(window.initLivePage);
            } else {
                window.P.when('A').execute((A) => {
                    A.on('amazonLiveEvent:initLivePage:available', function onAvailable() {
                        try{
                            initLiveWidget(window.initLivePage);
                        } catch(e) {
                            window.P.log('Error in initLivePage - could not load live player. ' + e, 'FATAL', 'AmazonLiveFlagshipAssets');
                            if (window.ue && window.ue.count) {
                                window.ue.count("AmazonLivePortal:LiveWidget:PlayerLoadErrorCount", 1);
                            }
                        }
                        A.off('amazonLiveEvent:initLivePage:available', onAvailable);
                    });
                });
            }
        }
    });
}));</script>
